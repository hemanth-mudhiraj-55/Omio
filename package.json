{
  "name": "evalixa",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "cd frontend && npm run build && cd .. && node scripts/prerender-meta.mjs",
    "reinstall:clean": "node scripts/reinstall-clean.mjs",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "npm --prefix frontend run lint",
    "lint:backend": "npm --prefix backend run lint",
    "format": "prettier --write \"frontend/src/**/*.{js,jsx,css}\" \"backend/**/*.js\" --ignore-path .gitignore",
    "format:check": "prettier --check \"frontend/src/**/*.{js,jsx,css}\" \"backend/**/*.js\" --ignore-path .gitignore",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "npm --prefix backend run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2"
  },
  "lint-staged": {
    "frontend/src/**/*.{js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "backend/**/*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.11.1",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.2",
  "volta": {
    "node": "22.14.0",
    "npm": "10.9.2"
  }
}
